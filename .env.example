# Copy to .env and fill in your keys.
# All env var names match agent/config.py.

# --- LLM (Groq — https://console.groq.com/keys) ---
GROQ_API_KEY=
MODEL=llama-3.3-70b-versatile

# --- AppWorld run ---
APPWORLD_EXPERIMENT=team_yourname
APPWORLD_DATASET=dev
MAX_TASKS=2
MAX_INTERACTIONS=60

# --- HydraDB (https://hydradb.com — hackathon bonus) ---
HYDRA_DB_API_KEY=
HYDRA_DB_TENANT=team_yourname
HYDRA_DB_ENABLED=1
HYDRA_DB_SEED_ON_START=0
HYDRA_DB_QUERY_ENABLED=0

# --- LLM tuning (optional) ---
# MAX_TOKENS=2500
# PLANNER_TEMPERATURE=0.2
# EXEC_TEMPERATURE=0.0

# --- Agent tuning (optional) ---
# MAX_RETRIEVED_APIS=12
# MAX_STEP_HISTORY=6
# MAX_REFLECTIONS=3

# --- Runtime paths (optional — defaults are project-local) ---
# IPYTHONDIR is auto-set to <project>/.ipython by agent/config.py
# For appworld play in a separate terminal:
#   export IPYTHONDIR="$(pwd)/.ipython"
